---
import "../styles/global.css";

export interface Props {
  title?: string;
  description?: string;
  path?: string; // canonical path, e.g. "/" or "/privacy-policy"
  home?: boolean; // include SoftwareApplication + FAQPage JSON-LD
}

const {
  title = "Listening Device for iPhone — Clarive: Amplify + Captions",
  description = "Turn your iPhone into a real-time listening device — amplify voices and read live captions in 40+ languages. Any headphones. Free & on-device.",
  path = "/",
  home = false,
} = Astro.props;

const SITE = "https://listeningdevice.app";
// Normalize to a trailing slash so canonical + og:url match the sitemap and the
// directory URLs Astro/Vercel actually serve (e.g. /privacy-policy/).
const canonicalPath = path.endsWith("/") ? path : `${path}/`;
const canonical = new URL(canonicalPath, SITE).href;
const ogImage = `${SITE}/og-image.png`;
const APP_URL = "https://apps.apple.com/us/app/listening-device-clarive/id6748903280";

const softwareLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "Listening Device: Clarive",
  alternateName: "Clarive",
  applicationCategory: "HealthApplication",
  operatingSystem: "iOS 17+",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  aggregateRating: { "@type": "AggregateRating", ratingValue: "4.8", ratingCount: "5" },
  description:
    "Real-time audio amplification and live captions for people with mild hearing difficulty. Turns iPhone and headphones into a powerful listening device.",
  url: SITE + "/",
  downloadUrl: APP_URL,
  installUrl: APP_URL,
  sameAs: [APP_URL],
  featureList: [
    "Real-time audio amplification",
    "Live captions in 40+ languages",
    "Voice Isolation and Focus Mode",
    "On-device processing — no audio sent to servers",
    "Works with any headphones",
  ],
  publisher: { "@type": "Organization", name: "Harshva Technology Private Limited" },
};

const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "What is a listening device?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "A listening device is any tool that helps amplify or capture sound to make it easier to hear. Clarive turns your iPhone into a digital listening device — using the built-in microphone and your headphones to amplify the world around you in real time.",
      },
    },
    {
      "@type": "Question",
      name: "Is Clarive the best listening device app for iPhone?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Clarive is purpose-built for iPhone and requires no extra hardware — just plug in any headphones. It combines real-time amplification, live captions in 40+ languages, and smart environment presets in one app, making it one of the most complete assistive listening solutions on iOS.",
      },
    },
    {
      "@type": "Question",
      name: "How does a listening device that connects to a phone work?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Clarive uses your iPhone's microphone to capture ambient sound, then processes and plays it back through your headphones in real time with amplification applied. Bluetooth headphones, AirPods, and wired EarPods all work. No external hardware required.",
      },
    },
    {
      "@type": "Question",
      name: "What is an assistive listening device?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "An assistive listening device (ALD) helps people with hearing difficulty hear more clearly. Clarive is a phone-based ALD that works on any iPhone running iOS 17 or later — no specialized equipment needed.",
      },
    },
    {
      "@type": "Question",
      name: "Does Clarive work without an internet connection?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Yes. Audio amplification works completely offline. Live captions use Apple's on-device speech recognition, which also works offline after the first language model download.",
      },
    },
    {
      "@type": "Question",
      name: "What headphones work with Clarive?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Any headphones that connect to your iPhone work — AirPods, wired EarPods, Bluetooth earphones, over-ear or in-ear headphones. Unlike Apple's Live Listen, you do not need AirPods or an MFi hearing device — Clarive works with whatever headphones you already own. No special hardware to buy.",
      },
    },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="generator" content={Astro.generator} />

    <!-- Icons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="mask-icon" href="/favicon.svg" color="#ff3b30" />

    <!-- Theme + iOS web-app -->
    <meta name="theme-color" content="#0a0a0c" />
    <meta name="color-scheme" content="dark" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Clarive" />
    <meta name="format-detection" content="telephone=no" />

    <!-- Native iOS Safari smart app banner -->
    <meta name="apple-itunes-app" content="app-id=6748903280" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Clarive" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />

    {home && (
      <script type="application/ld+json" set:html={JSON.stringify(softwareLd)} />
      <script type="application/ld+json" set:html={JSON.stringify(faqLd)} />
    )}

    <!-- Analytics -->
    <script is:inline defer src="/_vercel/insights/script.js"></script>
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-WD4RQW7ZZF"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }
      gtag("js", new Date());
      gtag("config", "G-WD4RQW7ZZF");
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
