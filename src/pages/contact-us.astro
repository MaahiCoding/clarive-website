---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
---
<Base
  title="Contact Us — Listening Device: Clarive"
  description="Get in touch with the Clarive support team. We're here to help with questions about Listening Device: Clarive, its features, and your account."
  path="/contact-us"
>
  <Nav />
  <main class="legal px-safe">
    <h1>Contact Us</h1>
    <p>
      We're here to assist you, anytime. Whether you've got questions about the app, its features, or simply need
      some guidance, don't hesitate to reach out — our support team is ready to help.
    </p>

    <div class="contact-card">
      <h2>Support enquiries</h2>
      <p><a class="contact-email" href="mailto:support@harshvatechnologies.com">support@harshvatechnologies.com</a></p>
    </div>

    <div class="contact-card">
      <h2>Company</h2>
      <p>Harshva Technology Private Limited</p>
      <p>Bageshwar, Uttarakhand, India, 263639</p>
      <p>CIN: U62091UT2023PTC016359</p>
    </div>
  </main>
  <Footer />
</Base>
