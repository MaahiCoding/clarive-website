---
import AppStoreBadge from "./AppStoreBadge.astro";
import Rings from "./Rings.astro";
---
<section class="relative overflow-hidden bg-ink px-safe py-24 sm:py-32" aria-label="Download Clarive">
  <div class="mx-auto max-w-4xl px-6">
    <div
      class="relative overflow-hidden rounded-[2.4rem] bg-gradient-crimson px-8 py-16 text-center glow-crimson-lg sm:px-16 sm:py-20"
    >
      <Rings class="left-1/2 top-1/2 h-[520px] w-[520px] -translate-x-1/2 -translate-y-1/2 opacity-40 mix-blend-overlay" />
      <div class="relative">
        <h2 class="text-4xl font-bold tracking-tight text-white sm:text-5xl">
          Start hearing clearly today.
        </h2>
        <p class="mx-auto mt-5 max-w-md text-lg text-white/85">
          Free to download. No account. No setup. Just plug in your headphones.
        </p>
        <div class="mt-10 flex flex-col items-center gap-4">
          <AppStoreBadge size="lg" />
          <p class="text-sm text-white/70">Free · iOS 17+ · Works with any headphones</p>
        </div>
      </div>
    </div>
  </div>
</section>
