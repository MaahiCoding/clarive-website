---
const reviews = [
  {
    title: "Game changer for noisy restaurants",
    body: "I'm 67 and restaurants have been a nightmare for years. With Clarive and my AirPods I can actually follow the conversation now. The Conversation preset is incredible. Wish I'd found this sooner.",
    name: "Margaret T.",
    initial: "M",
  },
  {
    title: "My mom uses this every single day",
    body: "Got my mum to try this and she hasn't put it down. The live captions are shockingly accurate. She uses it during phone calls too, which I didn't even expect. The privacy side gives us both peace of mind.",
    name: "David K.",
    initial: "D",
  },
  {
    title: "Genuinely no lag — I was shocked",
    body: "I tried two other apps before this and both had that annoying delay that makes it unusable. Clarive has essentially zero lag. Plugged in my AirPods Pro and it worked perfectly. The amplification is way louder than I expected.",
    name: "Ryan M.",
    initial: "R",
  },
];
---
<section id="reviews" class="relative bg-charcoal px-safe py-24 sm:py-32" aria-label="Reviews">
  <div class="mx-auto max-w-6xl px-6">
    <div class="mx-auto max-w-2xl text-center">
      <p class="section-label">Loved by listeners</p>
      <h2 class="section-title mt-3">What people are saying</h2>

      <div class="mt-8 flex items-center justify-center gap-4">
        <img src="/laurel.png" alt="" width="46" height="60" class="h-14 w-auto opacity-90" aria-hidden="true" />
        <div class="flex flex-col items-center">
          <span class="text-lg tracking-[0.2em] text-crimson" aria-hidden="true">★★★★★</span>
          <span class="mt-1 text-sm font-medium text-secondary">5.0 on the App Store</span>
        </div>
        <img src="/laurel.png" alt="" width="46" height="60" class="h-14 w-auto -scale-x-100 opacity-90" aria-hidden="true" />
      </div>
    </div>

    <div class="mt-14 grid gap-6 md:grid-cols-3">
      {reviews.map((r) => (
        <article class="reveal flex flex-col rounded-3xl border border-hairline bg-ink p-7 transition-colors duration-300 hover:border-crimson/40">
          <span class="text-base tracking-[0.15em] text-crimson" aria-hidden="true">★★★★★</span>
          <h3 class="mt-4 text-lg font-semibold text-white">{r.title}</h3>
          <p class="mt-3 flex-1 leading-relaxed text-secondary">"{r.body}"</p>
          <footer class="mt-6 flex items-center gap-3">
            <span
              class="grid h-10 w-10 place-items-center rounded-full bg-gradient-crimson text-sm font-semibold text-white"
              aria-hidden="true"
            >{r.initial}</span>
            <div class="flex flex-col leading-tight">
              <span class="text-sm font-semibold text-white">{r.name}</span>
              <span class="text-xs text-muted">App Store</span>
            </div>
          </footer>
        </article>
      ))}
    </div>
  </div>
</section>
