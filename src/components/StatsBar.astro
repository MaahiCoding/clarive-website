---
const stats = [
  { target: 40, suffix: "+", label: "Languages" },
  { target: 0, suffix: "ms", label: "Noticeable lag" },
  { target: 100, suffix: "%", label: "On-device" },
  { target: 5, suffix: "", label: "Sound presets" },
];
---
<section aria-label="At a glance" class="relative border-y border-hairline bg-charcoal px-safe">
  <div class="mx-auto grid max-w-6xl grid-cols-2 gap-y-8 px-6 py-12 md:grid-cols-4 md:divide-x md:divide-hairline">
    {stats.map((s) => (
      <div class="flex flex-col items-center text-center md:px-6">
        <div class="flex items-baseline text-4xl font-bold tracking-tight text-white sm:text-5xl">
          <span class="stat-num" data-target={s.target}>0</span>
          <span class="text-gradient">{s.suffix}</span>
        </div>
        <span class="mt-2 text-sm font-medium uppercase tracking-wider text-secondary">{s.label}</span>
      </div>
    ))}
  </div>
</section>

<script is:inline>
  (() => {
    const ease = (p) => 1 - Math.pow(1 - p, 3);
    const run = (el) => {
      const target = +el.dataset.target;
      const dur = 1300;
      const start = performance.now();
      const tick = (now) => {
        const p = Math.min((now - start) / dur, 1);
        el.textContent = Math.round(target * ease(p));
        if (p < 1) requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);
    };
    const nums = document.querySelectorAll(".stat-num");
    if (!nums.length) return;
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            run(e.target);
            io.unobserve(e.target);
          }
        });
      },
      { threshold: 0.6 }
    );
    nums.forEach((n) => io.observe(n));
  })();
</script>
