---
import PhoneFrame from "./PhoneFrame.astro";
import Rings from "./Rings.astro";

export interface Props {
  id?: string;
  label: string;
  title: string;
  body: string;
  bullets?: string[];
  img: string;
  alt: string;
  flip?: boolean;
  tint?: boolean; // subtle crimson-tinted background band
}
const { id, label, title, body, bullets = [], img, alt, flip = false, tint = false } = Astro.props;
---
<section
  id={id}
  class={`relative overflow-hidden px-safe py-24 sm:py-28 ${tint ? "bg-charcoal" : "bg-ink"}`}
  aria-label={title}
>
  {tint && (
    <div
      class="pointer-events-none absolute inset-0"
      aria-hidden="true"
      style="background: radial-gradient(120% 80% at 50% 0%, rgba(255,59,48,0.07) 0%, transparent 55%);"
    ></div>
  )}
  <div
    class={`relative mx-auto flex max-w-6xl flex-col items-center gap-14 px-6 lg:grid lg:grid-cols-2 lg:gap-16 ${flip ? "lg:[&>*:first-child]:order-2" : ""}`}
  >
    <!-- Text -->
    <div class="max-w-xl">
      <p class="section-label">{label}</p>
      <h2 class="section-title mt-3">{title}</h2>
      <p class="mt-5 text-lg leading-relaxed text-secondary">{body}</p>
      {bullets.length > 0 && (
        <ul class="mt-8 space-y-4">
          {bullets.map((b) => (
            <li class="flex items-start gap-3 text-white/90">
              <span
                class="mt-0.5 grid h-6 w-6 shrink-0 place-items-center rounded-full bg-crimson/15 text-crimson"
                aria-hidden="true"
              >
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 6 9 17l-5-5" />
                </svg>
              </span>
              <span class="leading-snug">{b}</span>
            </li>
          ))}
        </ul>
      )}
    </div>

    <!-- Phone -->
    <div class="reveal relative flex items-center justify-center">
      <Rings class="left-1/2 top-1/2 h-[460px] w-[460px] -translate-x-1/2 -translate-y-1/2 opacity-70" />
      <PhoneFrame src={img} alt={alt} width={272} class="relative z-10" />
    </div>
  </div>
</section>
