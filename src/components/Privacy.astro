---
const points = [
  "No microphone data stored or transmitted",
  "No account or sign-in required",
  "Works fully offline after first launch",
  "Complies with Apple App Store privacy guidelines",
];
---
<section class="relative overflow-hidden bg-ink px-safe py-24 sm:py-32" aria-label="Privacy">
  <div class="mx-auto max-w-4xl px-6">
    <div
      class="relative overflow-hidden rounded-[2rem] border border-hairline bg-charcoal p-10 sm:p-14"
    >
      <div
        class="pointer-events-none absolute -right-24 -top-24 h-72 w-72 rounded-full"
        aria-hidden="true"
        style="background: radial-gradient(circle, rgba(255,59,48,0.16) 0%, transparent 65%);"
      ></div>

      <div class="relative flex flex-col items-start gap-8 sm:flex-row sm:items-center sm:gap-12">
        <div
          class="grid h-20 w-20 shrink-0 place-items-center rounded-3xl bg-gradient-crimson text-white glow-crimson"
          aria-hidden="true"
        >
          <svg width="38" height="38" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z" />
            <path d="m9 12 2 2 4-4" />
          </svg>
        </div>
        <div>
          <p class="section-label">Privacy first</p>
          <h2 class="mt-3 text-3xl font-bold tracking-tight text-white sm:text-4xl">
            Your audio never leaves your iPhone.
          </h2>
          <p class="mt-4 leading-relaxed text-secondary">
            Everything in Clarive runs entirely on-device using Apple's built-in speech recognition.
            No servers. No accounts. No uploads. Your conversations are yours alone.
          </p>
        </div>
      </div>

      <ul class="relative mt-10 grid gap-x-8 gap-y-4 sm:grid-cols-2">
        {points.map((p) => (
          <li class="flex items-center gap-3 text-white/90">
            <span class="grid h-6 w-6 shrink-0 place-items-center rounded-full bg-crimson/15 text-crimson" aria-hidden="true">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 6 9 17l-5-5" />
              </svg>
            </span>
            {p}
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
