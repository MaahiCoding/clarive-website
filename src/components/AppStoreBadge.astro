---
// Native-style "Download on the App Store" badge.
export interface Props { class?: string; size?: "md" | "lg"; label?: string }
const {
  class: cls = "",
  size = "md",
  label = "Download Clarive on the App Store",
} = Astro.props;
const APP_URL = "https://apps.apple.com/us/app/listening-device-clarive/id6748903280";
const pad = size === "lg" ? "px-6 py-3.5" : "px-5 py-3";
const apple = size === "lg" ? 26 : 22;
const sub = size === "lg" ? "text-[12px]" : "text-[11px]";
const main = size === "lg" ? "text-[22px]" : "text-[19px]";
---
<a
  href={APP_URL}
  target="_blank"
  rel="noopener"
  aria-label={label}
  class={`appstore-badge group inline-flex items-center gap-3 rounded-2xl bg-white text-ink ${pad} font-medium transition-transform duration-300 ease-[cubic-bezier(0.22,1,0.36,1)] hover:-translate-y-0.5 active:translate-y-0 ${cls}`}
>
  <svg width={apple} height={apple} viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="shrink-0">
    <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z" />
  </svg>
  <span class="flex flex-col leading-none text-left">
    <span class={`${sub} font-medium tracking-wide text-ink/60`}>Download on the</span>
    <span class={`${main} font-semibold tracking-tight`}>App Store</span>
  </span>
</a>
