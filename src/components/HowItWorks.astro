---
const steps = [
  { n: "1", title: "Connect headphones", body: "Plug in any wired or Bluetooth headphones — AirPods, EarPods, anything. Clarive detects them automatically." },
  { n: "2", title: "Tap Amplify", body: "Your iPhone mic captures the sound around you and plays it back through your headphones in real time." },
  { n: "3", title: "See live captions", body: "Every word transcribed on screen as it's spoken — so you never miss what's being said." },
];
---
<section class="relative bg-ink px-safe py-24 sm:py-32" aria-label="How Clarive works">
  <div class="mx-auto max-w-6xl px-6">
    <div class="mx-auto max-w-2xl text-center">
      <p class="section-label">Three simple steps</p>
      <h2 class="section-title mt-3">From pocket to hearing aid in seconds</h2>
    </div>

    <div class="mt-16 grid gap-6 md:grid-cols-3 md:gap-8">
      {steps.map((s, i) => (
        <div class="reveal group relative rounded-3xl border border-hairline bg-charcoal p-8 transition-colors duration-300 hover:border-crimson/40">
          <div
            class="grid h-12 w-12 place-items-center rounded-2xl bg-gradient-crimson text-lg font-bold text-white glow-crimson"
          >
            {s.n}
          </div>
          <h3 class="mt-6 text-xl font-semibold text-white">{s.title}</h3>
          <p class="mt-3 leading-relaxed text-secondary">{s.body}</p>
          {i < steps.length - 1 && (
            <span
              class="absolute right-6 top-1/2 hidden -translate-y-1/2 translate-x-1/2 text-2xl text-crimson/40 md:block"
              aria-hidden="true"
            >→</span>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
