---
// Decorative concentric "soundwave" rings + radial glow. Purely atmospheric.
export interface Props { class?: string; pulse?: boolean }
const { class: cls = "", pulse = false } = Astro.props;
---
<div class={`pointer-events-none absolute ${cls}`} aria-hidden="true">
  <div
    class="absolute inset-0 rounded-full"
    style="background: radial-gradient(circle at center, rgba(255,59,48,0.28) 0%, rgba(255,59,48,0.10) 30%, transparent 62%); filter: blur(8px);"
  >
  </div>
  <svg viewBox="0 0 600 600" class="relative h-full w-full overflow-visible">
    <g fill="none" stroke="var(--color-crimson)" stroke-opacity="0.16">
      <circle cx="300" cy="300" r="70" stroke-opacity="0.42" />
      <circle cx="300" cy="300" r="130" stroke-opacity="0.30" />
      <circle cx="300" cy="300" r="200" stroke-opacity="0.20" />
      <circle cx="300" cy="300" r="270" stroke-opacity="0.12" />
      <circle cx="300" cy="300" r="290" stroke-opacity="0.07" />
    </g>
    {pulse && (
      <g fill="none" stroke="var(--color-crimson)">
        <circle cx="300" cy="300" r="70" style="transform-origin:center;animation:ripple 4s ease-out infinite" />
        <circle cx="300" cy="300" r="70" style="transform-origin:center;animation:ripple 4s ease-out 2s infinite" />
      </g>
    )}
  </svg>
</div>
